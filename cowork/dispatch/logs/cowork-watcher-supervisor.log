        cleaned = re.sub(r"\s+紐⑥쭛湲곌컙\s*:\s*\d{4}[./-]\d{1,2}[./-]\d{1,2}\s*-\s*\d{4}[./-]\d{1,2}[./-]\d{1,2}.*$", "", cleaned)
        cleaned = re.sub(r"\s+?됱궗?쇱옄\s*:.*$", "", cleaned)
        cleaned = re.sub(r"\s+?됱궗?μ냼\s*:.*$", "", cleaned)
