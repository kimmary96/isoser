        return items

    def parse_html(self, html: str, *, base_url: str) -> List[Dict]:
        soup = self.soup_from_html(html)
        items: List[Dict] = []
        for anchor in soup.select("a[href*='/in_appView.do?ANN_NO=']"):
            title = self._clean_title(anchor.get_text(" ", strip=True), _text(anchor.find_parent(["li", "div", "article"]) or anchor))
            if not title:
                continue
            container = anchor.find_parent(["li", "div", "article"]) or anchor
            raw_text = _text(container)
            item = self.make_item(
                title=title,
                link=self.absolute_url(base_url, anchor.get("href", "")),
                raw=raw_text,
                raw_deadline=self.extract_date(raw_text),
                category_hint=self._resolve_category(raw_text),
                target=["以묒옣??],
            )
            if item is not None:
                items.append(item)
        for container in soup.select("li, tr, .list-item, .card, article"):
            anchor = container.select_one("a[href]")
            if anchor is None:
                continue
            title = self._clean_title(anchor.get_text(" ", strip=True), _text(container))
            href = anchor.get("href", "")
            if (
                href.startswith("javascript:")
                or "/in_appView.do?ANN_NO=" in href
                or self._is_menu_like_title(title)
            ):
                continue
            raw_text = _text(container)
            if not title or not any(token in raw_text for token in ("50+", "以묒옣??, "援먯쑁", "?쇱옄由?, "紐⑥쭛", "媛뺤쥖")):
                continue
            if not any(token in raw_text for token in ("紐⑥쭛", "梨꾩슜", "媛뺤쥖", "?좎껌")) and self.extract_date(raw_text) is None:
                continue
            item = self.make_item(
                title=title,
                link=self.absolute_url(base_url, href),
                raw=raw_text,
                raw_deadline=self.extract_date(raw_text),
                category_hint=self._resolve_category(raw_text),
                target=["以묒옣??],
            )
            if item is not None:
                items.append(item)
        return items

    def _resolve_category(self, text: str) -> str:
        if any(keyword in text for keyword in ("?쇱옄由?, "梨꾩슜", "痍⑥뾽")):
            return "痍⑥뾽"
        return "援먯쑁"

    def _clean_title(self, title: str, raw_text: str) -> str:
        cleaned = self._clean_text(title)
        if any(token in cleaned for token in ("紐⑥쭛湲곌컙", "紐⑥쭛?몄썝", "?쒕룞鍮?, "?됱궗?쇱옄", "?됱궗?μ냼")):
            cleaned = raw_text
        cleaned = re.sub(r"^(湲고?|誘쇨컙梨꾩슜怨듦퀬|梨꾩슜?ㅻ챸??痍⑥뾽 ?덈젴|AI ?붿???援먯쑁|嫄닿컯紐쎈븙 援먯쑁|50?뚮윭?ㅼ꽱??援먯쑁)\s+", "", cleaned)
        cleaned = re.sub(r"\s+?쒕룞鍮?s*:.*$", "", cleaned)
        cleaned = re.sub(r"\s+紐⑥쭛?몄썝\s*:.*$", "", cleaned)
        cleaned = re.sub(r"\s+紐⑥쭛湲곌컙\s*:\s*\d{4}[./-]\d{1,2}[./-]\d{1,2}\s*-\s*\d{4}[./-]\d{1,2}[./-]\d{1,2}.*$", "", cleaned)
        cleaned = re.sub(r"\s+?됱궗?쇱옄\s*:.*$", "", cleaned)
        cleaned = re.sub(r"\s+?됱궗?μ냼\s*:.*$", "", cleaned)
        cleaned = re.sub(r"\s+?좎껌\s*[쨌쨌]\s*?묒닔?섍린.*$", "", cleaned)
        return self._clean_text(cleaned)

    def _is_menu_like_title(self, title: str) -> bool:
        if not title:
            return True
        if title in {"以묒옣?꾩랬?낆궗愿?숆탳", "痍⑥뾽?곷떞", "吏곸뾽援먯쑁", "痍⑥뾽吏??, "湲곗뾽吏??, "?쇱옄由?李몄뿬 ?좎껌", "李몄뿬 ?좎껌", "?좎껌?섍린"}:
            return True
        return bool(re.fullmatch(r"(?쇱옄由?援먯쑁|媛뺤쥖)\s*李몄뿬\s*?좎껌", title))


