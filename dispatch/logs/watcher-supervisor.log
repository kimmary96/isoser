+    def _tokenize_text(self, value: Any) -> list[str]:
+        if value is None:
+            return []
+        text = str(value).strip().lower()
+        if not text:
+            return []
+        tokens: list[str] = []
+        for token in TOKEN_PATTERN.findall(text):
+            if len(token) < 2:
+                continue
+            if re.fullmatch(r"[가-힣]+", token) and len(token) <= 2:
+                continue
+            tokens.append(token)
+        return tokens
+
+    def _profile_keywords(
