"use client";

import type { ChangeEvent } from "react";
import { useEffect, useState } from "react";
import { useRouter } from "next/navigation";

import {
  createActivity,
  deleteActivity,
  getActivityDetail,
  saveCoachSession,
  updateActivity,
  uploadActivityImages,
} from "@/lib/api/app";
