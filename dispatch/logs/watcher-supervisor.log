    result = scheduler.run_all_collectors(upsert=False)
    assert [source['source'] for source in result['sources']] == ['tier1', 'broken-tier3', 'KOBIA', 'KISED']
    assert result['sources'][1]['status'] == 'collector_exception'
    assert result['sources'][2]['status'] == 'dry_run'
    assert result['sources'][3]['status'] == 'dry_run'
finally:
    scheduler.COLLECTORS = original_collectors
    scheduler._create_supabase_client = original_factory

