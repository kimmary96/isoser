+    const score = programId ? relevanceItems[programId]?.relevance_score : undefined;
+    if (typeof score !== "number" || Number.isNaN(score)) return;
+    if (score > winnerScore) {
+      winnerIndex = index;
+      winnerScore = score;
+    }
+  });
+
+  return winnerIndex;
+}
 
