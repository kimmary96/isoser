        {error && <p className="text-sm text-red-600">{error}</p>}

        {loading ? (
          <div className="rounded-3xl border border-slate-200 bg-white p-8 text-slate-500 shadow-[0_16px_40px_rgba(15,23,42,0.05)]">遺덈윭?ㅻ뒗 以?..</div>
        ) : (
