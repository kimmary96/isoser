+        if not text:
+            return []
+        tokens: list[str] = []
+        for token in TOKEN_PATTERN.findall(text):
+            if len(token) < 2:
+                continue
+            if re.fullmatch(r"[가-힣]+", token) and len(token) <= 2:
+                continue
+            tokens.append(token)
+        return tokens
