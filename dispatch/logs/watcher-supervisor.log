            'link': 'https://example.com/tier1',
            'raw_deadline': '2026-05-01',
            'category_hint': '창업',
            'source_meta': self.get_source_meta(),
            'raw': {'id': 1},
        }]

class FailingTier3Collector(BaseCollector):
    tier = 3
    source_name = 'broken-tier3'
    source_key = 'broken-tier3'
    def collect(self):
        raise RuntimeError('simulated failure')

class DummySupabase:
    def upsert_programs(self, rows):
        self.rows = list(rows)

original_collectors = scheduler.COLLECTORS
original_factory = scheduler._create_supabase_client
try:
    scheduler.COLLECTORS = [Tier1Collector(), FailingTier3Collector(), KobiaCollector(), KisedCollector()]
    scheduler._create_supabase_client = lambda: DummySupabase()
    KobiaCollector.collect = lambda self: [{
        'title': 'KOBIA 창업보육센터 네트워킹 데이',
