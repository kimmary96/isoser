# Google Gemini API 키 (https://aistudio.google.com/app/apikey 에서 발급)
GOOGLE_API_KEY=your_gemini_api_key

# ChromaDB 파일 저장 경로
CHROMA_PERSIST_DIR=./chroma_store

# Chroma seed 빌드용 공공데이터포털/고용24 키
DATA_GO_KR_SERVICE_KEY=
NCS_REFERENCE_API_KEY=
NCS_RESOURCE_API_KEY=
WORK24_OPEN_API_AUTH_KEY=

# Chroma seed 빌드용 공공 API 안내 URL
WORK24_OPEN_API_GUIDE_URL=https://www.work24.go.kr/cm/e/a/0110/selectOpenApiIntro.do
NCS_REFERENCE_API_URL=https://www.data.go.kr/data/15128213/openapi.do
NCS_RESOURCE_API_URL=https://www.data.go.kr/data/15086446/openapi.do
JOB_ABILITY_CODE_MAPPING_URL=https://www.data.go.kr/data/15154290/fileData.do

# Chroma seed 빌드용 로컬 참조 파일 경로 (backend 기준 상대 경로)
KNOW_MID_CATEGORY_CSV_PATH=../docs/직업중분류.CSV
KNOW_DETAIL_CATEGORY_CSV_PATH=../docs/직업세세분류.CSV
KNOW_SURVEY_RAW_CSV_PATH=../docs/2019년_한국직업정보(KNOW)_재직자조사_성격·지식_원자료.csv
KNOW_SURVEY_CODEBOOK_XLSX_PATH=../docs/2019년_한국직업정보(KNOW)_재직자조사_성격·지식_코드북.xlsx
