# Backend local runtime reads backend/.env
# Copy this file to backend/.env and fill in real values locally.

# Gemini 2.5 Flash key used for recommendation reasons / fit keywords
# Get it from Google AI Studio: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_ai_studio_api_key

# Supabase project URL used by backend admin REST calls
# Get it from Supabase Dashboard > Project Settings > API
# Example dashboard path: https://supabase.com/dashboard/project/<project-ref>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co

# Server-side admin key for Supabase REST/Auth calls
# Get the service_role key from the same Supabase API settings page above
# Do NOT use NEXT_PUBLIC_SUPABASE_ANON_KEY here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional request timeout for backend -> Supabase admin requests
SUPABASE_TIMEOUT_SECONDS=10

ENABLE_HRD_COLLECTOR=false

# Admin route secret for POST /admin/* endpoints
# This is app-local, not issued by Supabase. Generate one locally, for example:
# PowerShell: [guid]::NewGuid().Guid
# Python: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET_KEY=generate_a_random_secret_for_admin_routes

# Work24 OpenAPI guide / signup page
# Official guide page used by the codebase: https://www.work24.go.kr/cm/e/a/0110/selectOpenApiIntro.do
WORK24_OPEN_API_GUIDE_URL=https://www.work24.go.kr/cm/e/a/0110/selectOpenApiIntro.do

# Work24 training-course API auth key used by POST /admin/sync/programs
# Request/copy the authKey issued for the Work24 training OpenAPI service
# Guide page: https://www.work24.go.kr/cm/e/a/0110/selectOpenApiIntro.do
WORK24_TRAINING_AUTH_KEY=your_work24_training_auth_key

# Shared / fallback Work24 auth key used by some other Work24 adapters
# If your team uses one common authKey, this can be the same value as WORK24_TRAINING_AUTH_KEY
# Guide page: https://www.work24.go.kr/cm/e/a/0110/selectOpenApiIntro.do
WORK24_OPEN_API_AUTH_KEY=your_work24_open_api_auth_key

# Optional older / auxiliary provider keys left here only if that integration is still used
HRD_API_KEY=
WORK24_API_KEY=
KSTARTUP_API_KEY=

SLACK_SIGNING_SECRET=
SLACK_APPROVER_USER_IDS=U12345678,U87654321
